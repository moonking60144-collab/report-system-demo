<mxfile host="app.diagrams.net" modified="2026-06-18T00:00:00.000Z" agent="Codex" version="26.0.0" type="device"><diagram name="Demo 資料流架構" id="report-demo-arch"><mxGraphModel dx="1500" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="980" background="#ffffff" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="報工系統 Demo — 資料流架構" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="70" y="34" width="920" height="42" as="geometry" /></mxCell><mxCell id="subtitle" value="正式版資料流原樣保留；Demo Mode 只把外部 Ragic SaaS 換成 MockRagicClient，不同步正式資料或 .nui" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#64748b;" vertex="1" parent="1"><mxGeometry x="72" y="78" width="1180" height="26" as="geometry" /></mxCell><mxCell id="ui" value="&lt;b&gt;React UI&lt;/b&gt;&lt;br&gt;&lt;br&gt;報工列表 / 明細 / 停機頁&lt;br&gt;Stale-while-refresh&lt;br&gt;更新時維持目前畫面" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#e0f2fe;strokeColor=#0284c7;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="325" height="150" as="geometry" /></mxCell><mxCell id="dev" value="&lt;b&gt;/dev 開發者入口&lt;/b&gt;&lt;br&gt;&lt;br&gt;欄位索引搜尋&lt;br&gt;資料流展示卡&lt;br&gt;Demo 帳密 demo/demo" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#eff6ff;strokeColor=#38bdf8;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="70" y="370" width="325" height="150" as="geometry" /></mxCell><mxCell id="sse" value="&lt;b&gt;SSE Realtime Bus&lt;/b&gt;&lt;br&gt;&lt;br&gt;mutation / sync 完成後推事件&lt;br&gt;前端 deferred refresh，不清空畫面" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="70" y="760" width="325" height="136" as="geometry" /></mxCell><mxCell id="backend" value="&lt;b&gt;Express + TypeScript Backend&lt;/b&gt;&lt;br&gt;&lt;br&gt;工單拆解 / 工時計算 / 良率邏輯&lt;br&gt;row-level 編輯鎖與驗鎖&lt;br&gt;idempotency / task registry&lt;br&gt;Record audit log" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#ccfbf1;strokeColor=#0f9f8f;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="515" y="145" width="425" height="198" as="geometry" /></mxCell><mxCell id="governance" value="&lt;b&gt;上游治理層&lt;/b&gt;&lt;br&gt;&lt;br&gt;4 lane scheduler + token bucket&lt;br&gt;前景 / 寫入保留 token 預算&lt;br&gt;Circuit breaker + read/write retry" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#fff7ed;strokeColor=#f97316;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="1060" y="140" width="350" height="158" as="geometry" /></mxCell><mxCell id="mock" value="&lt;b&gt;MockRagicClient&lt;/b&gt;&lt;br&gt;&lt;br&gt;in-memory demo fixture&lt;br&gt;模擬 Ragic Form 104 / 105 / 16&lt;br&gt;故障注入：延遲 / 失敗 / 掉欄位" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="1060" y="360" width="350" height="144" as="geometry" /></mxCell><mxCell id="verify" value="&lt;b&gt;Write verify&lt;/b&gt;&lt;br&gt;&lt;br&gt;寫入後讀回比對&lt;br&gt;mismatch 才 DELETE 止血&lt;br&gt;timeout 轉背景 re-verify" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="1060" y="560" width="350" height="150" as="geometry" /></mxCell><mxCell id="sync" value="&lt;b&gt;Sync worker&lt;/b&gt;&lt;br&gt;&lt;br&gt;全量對帳寫入 pending generation&lt;br&gt;replay 期間變更後 promote active" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#fef9c3;strokeColor=#ca8a04;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="1060" y="770" width="350" height="126" as="geometry" /></mxCell><mxCell id="sqlite" value="&lt;b&gt;SQLite Read Model&lt;/b&gt;&lt;br&gt;&lt;br&gt;active generation：前景列表 / 明細 / 分頁統計直接讀取&lt;br&gt;pending generation：同步期間隔離寫入&lt;br&gt;完成後原子切換；失敗時舊 snapshot 仍可服務&lt;br&gt;熱查詢從 300ms+ 壓到 10ms 內" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#ede9fe;strokeColor=#7c3aed;strokeWidth=2;fontFamily=Arial;fontSize=16;fontColor=#334155;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1"><mxGeometry x="515" y="560" width="445" height="242" as="geometry" /></mxCell><mxCell id="e-ui-backend" value="① 查詢 / 操作" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#0284c7;strokeWidth=3;fontColor=#0284c7;fontStyle=1;fontSize=12;" edge="1" parent="1" source="ui" target="backend"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="e-dev-backend" value="欄位索引 / 診斷 API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#38bdf8;strokeWidth=3;fontColor=#38bdf8;fontStyle=1;fontSize=12;" edge="1" parent="1" source="dev" target="backend"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="455" y="445" /><mxPoint x="455" y="282" /></Array></mxGeometry></mxCell><mxCell id="e-backend-governance" value="③ 寫入 / fallback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#f97316;strokeWidth=3;fontColor=#f97316;fontStyle=1;fontSize=12;" edge="1" parent="1" source="backend" target="governance"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="e-governance-mock" value="④ Demo upstream" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#f97316;strokeWidth=3;fontColor=#f97316;fontStyle=1;fontSize=12;" edge="1" parent="1" source="governance" target="mock"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="e-mock-verify" value="⑤ 寫後驗證" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#dc2626;strokeWidth=3;fontColor=#dc2626;fontStyle=1;fontSize=12;" edge="1" parent="1" source="mock" target="verify"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="e-mock-sync" value="⑥ 背景對帳" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#ca8a04;strokeWidth=3;fontColor=#ca8a04;fontStyle=1;fontSize=12;" edge="1" parent="1" source="mock" target="sync"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1465" y="560" /><mxPoint x="1465" y="682" /></Array></mxGeometry></mxCell><mxCell id="e-backend-sqlite" value="② 前景讀 active generation" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#7c3aed;strokeWidth=3;fontColor=#7c3aed;fontStyle=1;fontSize=12;" edge="1" parent="1" source="backend" target="sqlite"><mxGeometry relative="1" as="geometry"></mxGeometry></mxCell><mxCell id="e-sync-sqlite" value="⑦ pending → active" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#7c3aed;strokeWidth=3;fontColor=#7c3aed;fontStyle=1;fontSize=12;" edge="1" parent="1" source="sync" target="sqlite"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1018" y="842" /><mxPoint x="993" y="805" /></Array></mxGeometry></mxCell><mxCell id="e-sqlite-sse" value="⑧ 完成事件" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=3;fontColor=#16a34a;fontStyle=1;fontSize=12;" edge="1" parent="1" source="sqlite" target="sse"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="450" y="720" /><mxPoint x="450" y="828" /></Array></mxGeometry></mxCell><mxCell id="e-sse-ui" value="⑨ 無痛背景更新" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#16a34a;strokeWidth=3;fontColor=#16a34a;fontStyle=1;fontSize=12;" edge="1" parent="1" source="sse" target="ui"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="36" y="828" /><mxPoint x="36" y="225" /></Array></mxGeometry></mxCell><mxCell id="footer" value="可展示重點：generation swap、write verify、上游限流治理、SSE 無痛刷新、/dev 欄位索引；所有資料皆來自 demo fixture。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#64748b;" vertex="1" parent="1"><mxGeometry x="70" y="928" width="1280" height="26" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>