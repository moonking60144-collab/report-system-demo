<mxfile host="app.diagrams.net" modified="2026-06-18T00:00:00.000Z" agent="Codex" version="26.0.0" type="device"><diagram name="Demo 資料流架構" id="report-demo-arch"><mxGraphModel dx="1500" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="940" background="#ffffff" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="報工系統 Demo — 資料流架構" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#0f172a;" vertex="1" parent="1"><mxGeometry x="70" y="34" width="920" height="42" as="geometry" /></mxCell><mxCell id="subtitle" value="正式版資料流原樣保留；Demo Mode 只把外部 Ragic SaaS 換成 MockRagicClient，不同步正式資料或 .nui" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontColor=#64748b;" vertex="1" parent="1"><mxGeometry x="72" y="78" width="1180" height="26" as="geometry" /></mxCell><mxCell id="ui" value="&lt;b&gt;React UI&lt;/b&gt;&lt;br&gt;報工列表 / 明細 / 停機頁&lt;br&gt;Stale-while-refresh&lt;br&gt;更新時維持目前畫面" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#e0f2fe;strokeColor=#0284c7;" vertex="1" parent="1"><mxGeometry x="70" y="160" width="300" height="126" as="geometry" /></mxCell><mxCell id="dev" value="&lt;b&gt;/dev 開發者入口&lt;/b&gt;&lt;br&gt;欄位索引搜尋&lt;br&gt;資料流展示卡&lt;br&gt;Demo 帳密 demo/demo" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#f0f9ff;strokeColor=#38bdf8;" vertex="1" parent="1"><mxGeometry x="70" y="355" width="300" height="122" as="geometry" /></mxCell><mxCell id="sse" value="&lt;b&gt;SSE Realtime Bus&lt;/b&gt;&lt;br&gt;mutation / sync 完成後推事件&lt;br&gt;前端 deferred refresh&lt;br&gt;不清空目前畫面" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#dcfce7;strokeColor=#16a34a;" vertex="1" parent="1"><mxGeometry x="70" y="702" width="300" height="112" as="geometry" /></mxCell><mxCell id="api" value="&lt;b&gt;Express + TypeScript Backend&lt;/b&gt;&lt;br&gt;工單拆解 / 工時計算 / 良率邏輯&lt;br&gt;row-level 編輯鎖與驗鎖&lt;br&gt;idempotency / task registry&lt;br&gt;Record audit log" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#ccfbf1;strokeColor=#0d9488;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="470" y="150" width="380" height="174" as="geometry" /></mxCell><mxCell id="gov" value="&lt;b&gt;上游治理層&lt;/b&gt;&lt;br&gt;4 lane scheduler + token bucket&lt;br&gt;前景 / 寫入保留 token 預算&lt;br&gt;Circuit breaker&lt;br&gt;read/write retry 分流" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#fff7ed;strokeColor=#f97316;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="470" y="395" width="380" height="148" as="geometry" /></mxCell><mxCell id="sqlite" value="&lt;b&gt;SQLite Read Model&lt;/b&gt;&lt;br&gt;active generation：前景列表 / 明細 / 分面統計直接讀取&lt;br&gt;pending generation：同步期間隔離寫入，完成後原子切換&lt;br&gt;&lt;b&gt;效果：&lt;/b&gt;熱查詢從 300ms+ 壓到 10ms 內；同步失敗時舊 snapshot 仍可服務" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#ede9fe;strokeColor=#7c3aed;align=left;verticalAlign=top;fontSize=15;" vertex="1" parent="1"><mxGeometry x="470" y="670" width="870" height="160" as="geometry" /></mxCell><mxCell id="mock" value="&lt;b&gt;MockRagicClient&lt;/b&gt;&lt;br&gt;in-memory demo fixture&lt;br&gt;模擬 Ragic Form 104 / 105 / 16&lt;br&gt;故障注入：延遲 / 失敗 / 掉欄位" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#f8fafc;strokeColor=#64748b;" vertex="1" parent="1"><mxGeometry x="990" y="150" width="350" height="136" as="geometry" /></mxCell><mxCell id="verify" value="&lt;b&gt;Write verify&lt;/b&gt;&lt;br&gt;寫入後讀回比對&lt;br&gt;mismatch 才 DELETE 止血&lt;br&gt;timeout 轉背景 re-verify" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#fee2e2;strokeColor=#dc2626;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="990" y="355" width="350" height="126" as="geometry" /></mxCell><mxCell id="sync" value="&lt;b&gt;Sync worker&lt;/b&gt;&lt;br&gt;全量對帳寫入 pending generation&lt;br&gt;replay 期間變更&lt;br&gt;最後 promote active pointer" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=14;fontColor=#0f172a;spacing=10;fillColor=#fef9c3;strokeColor=#ca8a04;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="990" y="542" width="350" height="118" as="geometry" /></mxCell><mxCell id="footer" value="可展示重點：generation swap、write verify、上游限流治理、SSE 無痛刷新、/dev 欄位索引；所有資料皆來自 demo fixture。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;fontColor=#64748b;" vertex="1" parent="1"><mxGeometry x="70" y="870" width="1180" height="36" as="geometry" /></mxCell><mxCell id="e1" value="① 查詢 / 操作" style="endArrow=classic;html=1;strokeColor=#0284c7;strokeWidth=2.5;fontSize=12;fontColor=#0369a1;" edge="1" parent="1" source="ui" target="api"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e2" value="欄位索引 / 診斷 API" style="endArrow=classic;html=1;strokeColor=#38bdf8;strokeWidth=2.5;fontSize=12;fontColor=#0369a1;" edge="1" parent="1" source="dev" target="api"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e3" value="② 前景讀 active generation" style="endArrow=classic;html=1;strokeColor=#7c3aed;strokeWidth=2.5;fontSize=12;fontColor=#5b21b6;" edge="1" parent="1" source="api" target="sqlite"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e4" value="③ 寫入 / fallback 進治理層" style="endArrow=classic;html=1;strokeColor=#f97316;strokeWidth=2.5;fontSize=12;fontColor=#c2410c;" edge="1" parent="1" source="api" target="gov"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e5" value="④ 受限流治理的上游呼叫" style="endArrow=classic;html=1;strokeColor=#f97316;strokeWidth=2.5;fontSize=12;fontColor=#c2410c;" edge="1" parent="1" source="gov" target="mock"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e6" value="⑤ 寫後驗證" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontSize=12;fontColor=#b91c1c;" edge="1" parent="1" source="mock" target="verify"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e7" value="⑥ 背景對帳來源" style="endArrow=classic;html=1;strokeColor=#ca8a04;strokeWidth=2.5;fontSize=12;fontColor=#a16207;" edge="1" parent="1" source="mock" target="sync"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e8" value="⑦ pending → active" style="endArrow=classic;html=1;strokeColor=#7c3aed;strokeWidth=2.5;fontSize=12;fontColor=#5b21b6;" edge="1" parent="1" source="sync" target="sqlite"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e9" value="⑧ 完成事件" style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=2.5;fontSize=12;fontColor=#15803d;" edge="1" parent="1" source="sqlite" target="sse"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e10" value="⑨ 無痛背景更新" style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=2.5;fontSize=12;fontColor=#15803d;" edge="1" parent="1" source="sse" target="ui"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>