{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "test": "node -e \"require('fs').rmSync('.tmp-test-dist',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node --test .tmp-test-dist/tests/**/*.test.js",
    "dev": "node --watch --import tsx src/server.ts",
    "demo": "cross-env DEMO_MODE=true node --watch --import tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "audit:views": "node scripts/audit-work-report-views.js",
    "audit:form16-orphans": "tsx scripts/audit-form16-orphans.ts",
    "backup:sqlite": "node scripts/backup-sqlite.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Ragic report backend",
  "dependencies": {
    "axios": "1.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^25.2.0",
    "@types/node-cache": "^4.1.3",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
