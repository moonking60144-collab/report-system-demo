# Server
PORT=3000
NODE_ENV=development
SERVE_FRONTEND_FROM_BACKEND=false
FRONTEND_STATIC_DIR=

# 上游 SaaS 連線設定
UPSTREAM_PROTOCOL=https
UPSTREAM_DOMAIN=demo.local
UPSTREAM_API_KEY=

# Main form (Phase 1)
UPSTREAM_FORM_104_PATH=/default/forms8/104
UPSTREAM_FORM_104_TEST_PATH=
UPSTREAM_FORM_104_CLOSE_ACTION_BUTTON_ID=13
UPSTREAM_FORM_104_REOPEN_ACTION_BUTTON_ID=18
# Heading report form（目前 create/update 流程已收斂成只打 /c1/16 的 48）
UPSTREAM_FORM_105_PATH=/default/forms8/105
UPSTREAM_FORM_105_TEST_PATH=
UPSTREAM_FORM_105_CLOSE_ACTION_BUTTON_ID=13
UPSTREAM_FORM_105_REOPEN_ACTION_BUTTON_ID=18
UPSTREAM_FORM_16_PATH=/default/c1/16
UPSTREAM_FORM_16_TEST_PATH=
UPSTREAM_FORM_16_SAVE_ACTION_BUTTON_ID=48
UPSTREAM_FORM_16_WORK_ORDER_FIELD_ID=1006365
UPSTREAM_FORM_16_TYPE_FIELD_ID=1012669
UPSTREAM_FORM_16_PROCESS_FIELD_ID=1002195
UPSTREAM_FORM_16_DEP_FIELD_ID=1002221
UPSTREAM_FORM_16_PROD_TYPE_FIELD_ID=1002191
UPSTREAM_FORM_16_REMARK_FIELD_ID=1002177
UPSTREAM_FORM_16_DATE_FIELD_ID=1002190
UPSTREAM_ACTION_BUTTON_TIMEOUT_MS=30000
UPSTREAM_WRITE_TARGET=test

# Linked source forms
UPSTREAM_SOURCE_MACHINE=/default/forms51/1
UPSTREAM_SOURCE_OPERATOR=/default/forms11/13
UPSTREAM_SOURCE_PROCESS=/default/forms51/3
UPSTREAM_CALLBACK_TOKEN=
UPSTREAM_CALLBACK_DELAY_MS=1000
UPSTREAM_CALLBACK_TASK_PERSIST_ENABLED=true
UPSTREAM_CALLBACK_TASK_STORE_FILE=./.cache/ragic-callback-tasks.v1.json

# Cache
CACHE_TTL=300
CACHE_CHECK_PERIOD=60
SQLITE_ENABLED=true
# 讀取是否優先走 SQLite（失敗會回退上游）
SQLITE_READ_ENABLED=true
# 分階段切換：預設先啟用 105；要一起啟用可改成 105,104
SQLITE_READ_FORMS=105
SQLITE_DB_FILE=./.cache/work-report-read-model.v1.sqlite3
SQLITE_SYNC_BATCH_SIZE=500
# server 可選：定時背景同步 SQLite（預設關閉）
SQLITE_AUTO_SYNC_ENABLED=false
# 留空時預設跟 SQLITE_READ_FORMS 一致
SQLITE_AUTO_SYNC_FORMS=
# 預設 30 分鐘
SQLITE_AUTO_SYNC_INTERVAL_MS=1800000
# backend 啟動後延遲多久再跑第一輪 auto sync
SQLITE_AUTO_SYNC_STARTUP_DELAY_MS=30000
FORM16_SQLITE_AUTO_SYNC_ENABLED=true
FORM16_SQLITE_REFRESH_INTERVAL_MS=60000
OPERATOR_OPTION_CACHE_TTL_MS=60000
UPSTREAM_READ_CONCURRENCY=12
UPSTREAM_SYNC_READ_CONCURRENCY=4
UPSTREAM_BACKGROUND_READ_CONCURRENCY=4
# 全域上游 request 上限（per second）；所有 lane 共用同一個 token bucket
# 4 條 lane 加總 22 個 slot 可能 burst 太多，這裡限制每秒不超過 N 個 outbound 請求
UPSTREAM_GLOBAL_RATE_PER_SECOND=8
UPSTREAM_GLOBAL_BURST_CAPACITY=12
UPSTREAM_QUEUE_TIMEOUT_MS=30000
UPSTREAM_READ_TIMEOUT_MS=15000
UPSTREAM_SYNC_READ_TIMEOUT_MS=60000
UPSTREAM_BACKGROUND_READ_TIMEOUT_MS=30000
UPSTREAM_WRITE_TIMEOUT_MS=30000
UPSTREAM_WRITE_CONCURRENCY=2
UPSTREAM_GET_RETRY_MAX=2
UPSTREAM_GET_RETRY_BASE_DELAY_MS=200
UPSTREAM_WRITE_RETRY_MAX=1
UPSTREAM_WRITE_RETRY_BASE_DELAY_MS=300
UPSTREAM_METRICS_WINDOW_SIZE=200
# 上游側連續失敗時開 circuit breaker（連續 N 筆失敗就停 M 毫秒不再打）
UPSTREAM_CIRCUIT_FAILURE_THRESHOLD=10
UPSTREAM_CIRCUIT_COOLDOWN_MS=30000
# 上線建議關閉，避免固定週期 health log 造成噪音
RUNTIME_HEALTH_LOG_ENABLED=false
RUNTIME_HEALTH_LOG_INTERVAL_MS=60000
REPORT_FULL_CACHE_ENABLED=true
REPORT_FULL_CACHE_TTL_MS=604800000
REPORT_FULL_CACHE_FILE=./.cache/reports-104-full.v1.json
REPORT_FULL_CACHE_STALE_WHILE_REVALIDATE=true
# 啟動後非阻塞預熱 /reports/full 快取（預設開啟）
REPORT_FULL_CACHE_PREWARM_ON_START=true
REPORT_FULL_CACHE_MAX_RECORDS=20000

# Create report performance tuning
CREATE_POLL_MAX_RETRY=3
CREATE_POLL_DELAY_MS=200
CREATE_SLOW_LOG_THRESHOLD_MS=3000
# 上線建議維持 false，避免 create 流程印出大量 debug 細節
CREATE_DEBUG_OPERATOR=false
CREATE_DEBUG_OPERATOR_KEY_LIMIT=30
CREATE_RECALC_ACTION_RETRY=1
CREATE_RECALC_VERIFY_RETRY=2
CREATE_RECALC_VERIFY_DELAY_MS=400
CREATE_RECALC_STRICT=false
CREATE_TASK_PERSIST_ENABLED=true
CREATE_TASK_STORE_FILE=./.cache/create-report-tasks.v1.json
CREATE_TASK_HISTORY_LIMIT=2000
WORK_REPORT_BATCH_DELETE_CONCURRENCY=3
WORK_REPORT_BATCH_CREATE_FINALIZE_RETRY=3
WORK_REPORT_BATCH_CREATE_FINALIZE_RETRY_DELAY_MS=1500
WORK_REPORT_TASK_REGISTRY_PERSIST_ENABLED=true
WORK_REPORT_TASK_REGISTRY_STORE_FILE=./.cache/work-report-task-registry.v1.json
WORK_REPORT_TASK_REGISTRY_HISTORY_LIMIT=5000

# Form 16 孤兒背景清理（2A/2B/2C 的兜底）
# 預設關閉；確認 idempotency + verify + rollback 上線穩定後再打開。
# 每 10 分鐘掃、createdAt > 10 分鐘才刪、單次最多 50 筆、範圍最近 90 天。
# 判定條件：workOrderNo 空 + 計畫停機!=Yes + 報工類別在白名單 + 開單者符合 + ERP料號不含 test
# CLEANUP_ENABLED=true 時 CREATOR_ACCOUNT 必填（用來把誤刪風險鎖在「系統 API 寫的」那批）；
# 空值時 bootstrap 會拒絕啟動
FORM16_ORPHAN_CLEANUP_ENABLED=false
FORM16_ORPHAN_CREATOR_ACCOUNT=

# System notice (single file + admin login)
SYSTEM_NOTICE_FILE=./.data/system-notice.v1.json
NOTICE_ADMIN_USERNAME=admin
# 使用 SHA-256 雜湊值（例如 echo -n "your-password" | sha256sum）
# Demo / 本機展示可用 demo / demo：
#   NOTICE_ADMIN_USERNAME=demo
#   NOTICE_ADMIN_PASSWORD_HASH=2a97516c354b68848cdbd8f54a226a0a55b21ed138e207ad6c5cbb9c00aa5aea
NOTICE_ADMIN_PASSWORD_HASH=
NOTICE_TOKEN_TTL_MINUTES=10080

# Demo mode（公開 demo URL 用）
# DEMO_MODE=true 時，系統以 in-memory MockRagicClient 跑，可呼叫 /api/__demo/reset 重置 fixture
# DEMO_RESET_KEY 留空時 env.ts 會自動產生一支 16-byte hex（server log 會印出）
DEMO_MODE=false
DEMO_RESET_KEY=

# CORS
# CORS_ORIGIN 支援逗號分隔多個 origin；或用 CORS_ORIGINS（同義，優先判讀）
# 開發用
CORS_ORIGIN=http://localhost:5173
# 正式環境範例（上線時改成你的 HTTPS 網域）
# CORS_ORIGIN=https://demo.local
# 多 origin 範例：CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5174
